# FastAPI backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project — used by the BROWSER for realtime Query-table updates.
# Use the ANON (public) key here, NOT the service key the backend uses.
# If these are omitted, the app automatically falls back to polling.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
